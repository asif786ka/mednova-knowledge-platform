# =============================================================================
# MedNova AI Knowledge Platform — environment configuration
# EVERYTHING here is OPTIONAL. With an empty .env the platform runs fully offline:
#   - hashing embedder (no model download)
#   - in-process NumPy vector store + NetworkX graph
#   - deterministic extractive answerer (no LLM key)
#   - in-memory response cache (no Redis)
# Set values below to upgrade each layer to a managed service.
# =============================================================================

# ---- LLM provider (via LiteLLM). Set ONE key to enable real generation. ----
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_HOST=http://localhost:11434     # local open-source models

# ---- Embeddings ----
# EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBED_DIM=384
# FORCE_HASH_EMBEDDINGS=false            # true = always use the offline hashing embedder

# ---- Cache / queue broker (Redis) ----
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL_SECONDS=3600

# ---- Managed graph / vector backends (design-ready, see SYSTEM_DESIGN.md) ----
# NEO4J_URI=neo4j+s://<id>.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=...
# ASTRA_DB_ID=...
# ASTRA_DB_APPLICATION_TOKEN=...

# ---- Observability (Langfuse tracing) ----
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

# ---- App ----
# CHUNK_SIZE=700
# CHUNK_OVERLAP=120
# TOP_K=5
# LOG_LEVEL=INFO
# SAMPLE_DOCS_DIR=./sample_docs
